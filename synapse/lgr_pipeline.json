{
  "name": "spark_az_lgr_pipeline",
  "properties": {
    "description": "Drives notebooks/lgr.ipynb with the spark_az parameter contract. Import into Synapse Studio, set the referenceName below to whatever you named the imported lgr notebook, then customise the 'notebooks' parameter default.",
    "activities": [
      {
        "name": "run_lgr",
        "type": "SynapseNotebook",
        "dependsOn": [],
        "policy": {
          "timeout": "1.00:00:00",
          "retry": 0,
          "retryIntervalInSeconds": 30,
          "secureOutput": false,
          "secureInput": false
        },
        "userProperties": [],
        "typeProperties": {
          "notebook": {
            "referenceName": "lgr",
            "type": "NotebookReference"
          },
          "parameters": {
            "pipeline_run_id": {
              "value": {
                "value": "@pipeline().RunId",
                "type": "Expression"
              },
              "type": "string"
            },
            "pipeline_name": {
              "value": {
                "value": "@pipeline().Pipeline",
                "type": "Expression"
              },
              "type": "string"
            },
            "log_table": {
              "value": "_meta.__pipeline_runlog",
              "type": "string"
            },
            "fail_fast": {
              "value": true,
              "type": "bool"
            },
            "default_timeout_seconds": {
              "value": 1800,
              "type": "int"
            },
            "notebooks": {
              "value": [
                {"path": "Shared/etl/extract"},
                {"path": "Shared/etl/transform"},
                {"path": "Shared/etl/load", "timeout_seconds": 3600}
              ],
              "type": "array"
            },
            "app_insights_connection_string": {
              "value": "",
              "type": "string"
            }
          }
        }
      }
    ],
    "annotations": [
      "spark_az"
    ]
  }
}
